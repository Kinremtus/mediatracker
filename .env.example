# ===== Mediatracker =====
# Скопируй в .env и заполни значения

# --- Безопасность ---
SECRET_KEY=

# --- PostgreSQL ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=tracker
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# --- Сервер ---
HOST=0.0.0.0
PORT=8080
RUST_LOG=info

# --- Внешние API ---
TMDB_API_KEY=
RAWG_API_KEY=

# --- MyAnimeList ---
MAL_CLIENT_ID=
MAL_CLIENT_SECRET=

# --- IGDB (игры) ---
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# --- Telegram (уведомления) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email ---
RESEND_API_KEY=
MAILERSEND_SMTP_USER=
MAILERSEND_SMTP_PASS=
EMAIL_FROM=
